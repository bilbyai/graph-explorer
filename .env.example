# CONNECTIONS_JSON_BASE64 is a JSON object encoded in base64 with the schema:
# {
#   connections: [
#     {
#       "name": "<name of the connection, such as 'China Entities'>",
#       "connection_url": "neo4j+s://XXXXXXXX.databases.neo4j.io",
#       "username": "neo4j (or other username)",
#       "password": "<the password>"
#     },
#     ...
#   ]
# }
CONNECTIONS_JSON_BASE64=

# Required for hosted deployments. Use `openssl rand -base64 32`.
BETTER_AUTH_SECRET=

# Public base URL for auth callbacks and cookies.
BETTER_AUTH_URL=http://localhost:3000

# Postgres database for better-auth user/session tables.
# Use a Neon pooled connection string in production.
DATABASE_URL=postgresql://user:password@localhost:5432/graph_explorer

# Required to send password reset emails. Create an API key at resend.com.
RESEND_API_KEY=

# Password reset emails are sent from noreply@bilby.ai. Verify bilby.ai in Resend.

# Explicit opt-in local/self-hosted bypass. Do not enable on public hosted apps.
GRAPH_EXPLORER_NO_AUTH_LOCAL=false
