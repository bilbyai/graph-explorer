{
  "name": "web",
  "version": "0.0.1",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "NODE_OPTIONS=--no-deprecation pnpm with-env next dev --turbopack",
    "devsafe": "rm -rf .next && NODE_OPTIONS=--no-deprecation pnpm with-env next dev --turbopack",
    "build": "NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" pnpm with-env next build",
    "start": "NODE_OPTIONS=--no-deprecation pnpm with-env next start",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "lint": "pnpm check",
    "format": "pnpm check:fix",
    "typecheck": "pnpm with-env tsc --noEmit",
    "with-env": "dotenv -e ../../.env --",
    "db:generate": "pnpm with-env drizzle-kit generate",
    "db:migrate": "pnpm with-env drizzle-kit migrate"
  },
  "dependencies": {
    "@t3-oss/env-core": "^0.13.11",
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.6.11",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "neo4j-driver": "^6.0.1",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "pg": "^8.20.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "reagraph": "^4.30.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@types/node": "^25.1.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "@workspace/typescript-config": "workspace:*",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
